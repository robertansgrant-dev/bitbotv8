# Binance API keys (not needed for paper mode)
TESTNET_API_KEY=
TESTNET_SECRET_KEY=
LIVE_API_KEY=
LIVE_SECRET_KEY=

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Bot defaults
DEFAULT_MODE=paper
DEFAULT_STYLE=scalping

# Trading parameters
SYMBOL=BTCUSDT
INITIAL_CAPITAL=1000.0
MAX_DAILY_LOSS_PCT=5.0
MAX_POSITION_VALUE_PCT=80.0
EMERGENCY_STOP=false
UPDATE_INTERVAL=5
